#!/usr/bin/env python3
"""CLI tool for managing BTRFS and ZFS filesystem snapshots.

Reads volume configuration from /etc/snapshots.conf and provides
a unified interface to create and list snapshots across filesystem types.

Usage:
    snapshotctl snapshot    Create snapshots for all configured volumes.
    snapshotctl list        List existing snapshots for all configured volumes.
"""

import calendar
import configparser
import re
from collections.abc import Iterator
from configparser import SectionProxy
from dataclasses import dataclass
from datetime import datetime, timedelta
import json
import subprocess as sp
from argparse import ArgumentParser
from typing import Literal

TIMESTAMP_FORMAT = "%Y%m%dT%H%M%S"


@dataclass(frozen=True)
class Snapshot:
    """A filesystem snapshot.

    Attributes:
        type: Filesystem type ("btrfs" or "zfs").
        target: The source subvolume or dataset that was snapshotted.
        location: Full path to the snapshot on disk.
        timestamp: When the snapshot was created.
    """

    type: str
    target: str
    location: str
    timestamp: datetime


class BTRFSSnapshotEngine:
    """Snapshot engine for BTRFS filesystems.

    Creates read-only snapshots and lists existing ones by shelling out
    to the ``btrfs`` CLI. Snapshot names follow the pattern
    ``<sanitized_location>_<YYYYMMDDTHHMMSS>``.
    """

    def _parse_subvol_line(self, line: str) -> dict[str, str]:
        """Parse a single line of ``btrfs subvolume list`` output.

        Splits the line into key-value pairs based on known keywords
        (ID, gen, cgen, top level, otime, path).
        """
        keywords = ["ID", "gen", "cgen", "top level", "otime", "path"]
        result = {}
        key_acc = ""
        val_acc = ""
        tokens = line.split()
        for token in tokens:
            if any(token in kw for kw in keywords):
                if val_acc:
                    result[key_acc.strip()] = val_acc.strip()
                    val_acc = ""
                    key_acc = ""
                key_acc += f"{token} "
            else:
                val_acc += f"{token} "
        result[key_acc.strip()] = val_acc.strip()
        return result

    def list_snapshots(self, config: SectionProxy) -> Iterator[Snapshot]:
        """List existing BTRFS snapshots for a configured volume.

        Runs ``btrfs subvolume list -s`` against the snapshot destination
        and yields snapshots whose names match the configured location.
        """
        snapshot_prefix = config["location"].removeprefix("/").replace("/", "_")
        command = f"btrfs subvolume list -s {config['snapshot_destination']}".split()
        output = sp.check_output(command).decode().strip()
        for row in output.split("\n"):
            snapshot = self._parse_subvol_line(row)

            snapshot_name, timestamp = snapshot["path"].rsplit("_", maxsplit=1)
            if snapshot_name != snapshot_prefix:
                continue
            timestamp = datetime.strptime(timestamp, TIMESTAMP_FORMAT)

            yield Snapshot(
                type="btrfs",
                target=config["location"],
                location=config["snapshot_destination"] + "/" + snapshot["path"],
                timestamp=timestamp,
            )

    def delete_snapshot(self, snapshot: Snapshot) -> None:
        """Delete a BTRFS snapshot."""
        command = f"btrfs subvolume delete {snapshot.location}".split()
        sp.check_output(command)

    def create_snapshot(self, config: SectionProxy, now: datetime) -> Snapshot:
        """Create a new read-only BTRFS snapshot for a configured volume."""
        now_str = now.strftime(TIMESTAMP_FORMAT)
        snapshot_name = (
            config["location"].removeprefix("/").replace("/", "_") + "_" + now_str
        )
        snapshot_location = f"{config['snapshot_destination']}/{snapshot_name}"
        command = f"btrfs subvolume snapshot -r {config['location']} {
            snapshot_location
        }".split()
        sp.check_output(command)
        return Snapshot(
            type="btrfs",
            target=config["location"],
            location=snapshot_location,
            timestamp=now,
        )


class ZFSSnapshotEngine:
    """Snapshot engine for ZFS filesystems.

    Creates snapshots and lists existing ones by shelling out to the
    ``zfs`` CLI. Snapshot names follow the pattern
    ``<dataset>@<YYYYMMDDTHHMMSS>``.
    """

    def list_snapshots(self, config: SectionProxy) -> Iterator[Snapshot]:
        """List existing ZFS snapshots for a configured volume.

        Runs ``zfs list -j -t snapshot`` and parses the JSON output.
        """
        command = f"zfs list -j -t snapshot {config['location']}".split()
        output = sp.check_output(command)
        data = json.loads(output)
        for obj in data["datasets"].values():
            timestamp = datetime.strptime(obj["snapshot_name"], TIMESTAMP_FORMAT)
            yield Snapshot(
                type="zfs",
                target=obj["dataset"],
                location=obj["name"],
                timestamp=timestamp,
            )

    def delete_snapshot(self, snapshot: Snapshot) -> None:
        """Delete a ZFS snapshot."""
        command = f"zfs destroy {snapshot.location}".split()
        sp.check_output(command)

    def create_snapshot(self, config: SectionProxy, now: datetime) -> Snapshot:
        """Create a new ZFS snapshot for a configured volume."""
        now_str = now.strftime(TIMESTAMP_FORMAT)
        snapshot_location = f"{config['location']}@{now_str}"
        command = f"zfs snapshot {snapshot_location}".split()
        sp.check_output(command)
        return Snapshot(
            type="zfs",
            target=config["location"],
            location=snapshot_location,
            timestamp=now,
        )


def parse_retention(retention_str: str) -> list[tuple[int, str]]:
    """Parse a retention string like '24h 7d 4w 12m' into (count, unit) pairs."""
    result = []
    for token in retention_str.strip().split():
        match = re.fullmatch(r"(\d+)([hdwm])", token)
        if not match:
            raise ValueError(f"Invalid retention token: {token!r}")
        count = int(match.group(1))
        unit = match.group(2)
        result.append((count, unit))
    return result


def period_start(now: datetime, unit: str) -> datetime:
    """Return the start of the current calendar period for the given unit."""
    if unit == "h":
        return now.replace(minute=0, second=0, microsecond=0)
    elif unit == "d":
        return now.replace(hour=0, minute=0, second=0, microsecond=0)
    elif unit == "w":
        day_start = now.replace(hour=0, minute=0, second=0, microsecond=0)
        return day_start - timedelta(days=day_start.weekday())
    elif unit == "m":
        return now.replace(day=1, hour=0, minute=0, second=0, microsecond=0)
    else:
        raise ValueError(f"Unknown retention unit: {unit!r}")


def offset_periods(dt: datetime, unit: str, n: int) -> datetime:
    """Add n calendar periods to dt (negative n to subtract)."""
    if unit == "h":
        return dt + timedelta(hours=n)
    elif unit == "d":
        return dt + timedelta(days=n)
    elif unit == "w":
        return dt + timedelta(weeks=n)
    elif unit == "m":
        month = dt.month + n
        year = dt.year
        while month > 12:
            month -= 12
            year += 1
        while month <= 0:
            month += 12
            year -= 1
        max_day = calendar.monthrange(year, month)[1]
        return dt.replace(year=year, month=month, day=min(dt.day, max_day))
    else:
        raise ValueError(f"Unknown retention unit: {unit!r}")


def get_n_time_windows_upto_reference(
    reference: datetime, n: int, interval: Literal["h", "d", "w", "m"]
) -> list[tuple[datetime, datetime]]:
    """
    Get n consecutive time slices of length of the given interval such
    that the reference is included in the last one.

    The time slices are always aligned with the calendar.

    Examples:
        1. reference=2026-04-04T01:36, n=3, interval="h"
            -> [(2026-04-03T23:00, 2026-04-04T00:00),
                (2026-04-04T00:00, 2026-04-04T01:00),
                (2026-04-04T01:00, 2026-04-04T02:00)]
        2. reference=2026-04-04T01:36, n=2, interval="d"
            -> [(2026-04-03T00:00, 2026-04-04T00:00),
                (2026-04-04T00:00, 2026-04-05T00:00)]
        3. reference=2026-04-04T01:36, n=2, interval="w"
            -> [(2026-03-23T00:00, 2026-03-30T00:00),
                (2026-03-30T00:00, 2026-04-06T00:00)]
    """
    anchor = period_start(reference, interval)
    windows = []
    for i in range(n):
        start = offset_periods(anchor, interval, -(n - 1 - i))
        end = offset_periods(start, interval, 1)
        windows.append((start, end))
    return windows


def compute_snapshots_to_keep(
    snapshots: list[Snapshot],
    retention: list[tuple[int, str]],
    now: datetime,
) -> set[Snapshot]:
    """Determine which snapshots to keep based on the retention policy.

    For each (count, unit) pair, creates ``count`` calendar-aligned time
    buckets and keeps the most recent snapshot in each bucket.
    """
    keep: set[Snapshot] = set()
    for count, unit in retention:
        for bucket_start, bucket_end in get_n_time_windows_upto_reference(
            now, count, unit
        ):
            best = None
            for s in snapshots:
                if bucket_start <= s.timestamp < bucket_end:
                    if best is None or s.timestamp > best.timestamp:
                        best = s
            if best is not None:
                keep.add(best)
    return keep


def format_snapshot(snapshot: Snapshot) -> str:
    """Format a snapshot as a tab-separated string of target, timestamp, type, and location."""
    return "\t".join(
        [
            snapshot.target,
            snapshot.timestamp.isoformat(timespec="seconds"),
            snapshot.type,
            snapshot.location,
        ]
    )


def cmd_list(engine, vol_cfg: SectionProxy) -> None:
    """Print all existing snapshots for a configured volume."""
    for snapshot in engine.list_snapshots(vol_cfg):
        print(format_snapshot(snapshot))


def cmd_snapshot(engine, vol_cfg: SectionProxy) -> None:
    """Create a new snapshot for a configured volume and print it."""
    snapshot = engine.create_snapshot(vol_cfg, datetime.now())
    print(format_snapshot(snapshot))


def cmd_sync(engine, vol_cfg: SectionProxy, section: str, dry_run: bool) -> None:
    """Create a snapshot and delete expired ones according to the retention policy.

    In dry-run mode, simulates the operation and prints what would be kept or deleted.
    """
    if "retention" not in vol_cfg:
        print(f"Skipping {section}: no retention policy")
        return
    now = datetime.now()
    retention = parse_retention(vol_cfg["retention"])
    all_snapshots = list(engine.list_snapshots(vol_cfg))
    if dry_run:
        simulated = Snapshot(
            type=vol_cfg["type"],
            target=vol_cfg["location"],
            location="(new snapshot)",
            timestamp=now,
        )
        all_snapshots.append(simulated)
        keep = compute_snapshots_to_keep(all_snapshots, retention, now)
        all_snapshots.sort(key=lambda s: s.timestamp)
        for s in all_snapshots:
            action = "KEEP" if s in keep else "DELETE"
            print(f"{action}\t{format_snapshot(s)}")
    else:
        new_snapshot = engine.create_snapshot(vol_cfg, now)
        print(f"Created\t{format_snapshot(new_snapshot)}")
        all_snapshots.append(new_snapshot)
        keep = compute_snapshots_to_keep(all_snapshots, retention, now)
        for s in all_snapshots:
            if s not in keep:
                try:
                    engine.delete_snapshot(s)
                    print(f"Deleted\t{format_snapshot(s)}")
                except sp.CalledProcessError as e:
                    print(f"Error deleting\t{format_snapshot(s)}: {e}")


if __name__ == "__main__":
    parser = ArgumentParser(description="Manage BTRFS and ZFS filesystem snapshots.")
    parser.add_argument("command", choices=["list", "snapshot", "sync"])
    parser.add_argument(
        "--dry",
        action="store_true",
        help="Show what sync would do without making changes.",
    )
    args = parser.parse_args()

    config = configparser.ConfigParser()
    config.read("/etc/snapshots.conf")
    engines = {
        "btrfs": BTRFSSnapshotEngine(),
        "zfs": ZFSSnapshotEngine(),
    }

    for section in config.sections():
        if section.startswith("volume."):
            vol_cfg = config[section]
            engine = engines[vol_cfg["type"]]
            if args.command == "list":
                cmd_list(engine, vol_cfg)
            elif args.command == "snapshot":
                cmd_snapshot(engine, vol_cfg)
            elif args.command == "sync":
                cmd_sync(engine, vol_cfg, section, args.dry)
